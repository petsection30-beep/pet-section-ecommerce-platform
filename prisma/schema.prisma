generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING_COD
  PENDING_VERIFICATION
  CONFIRMED
  SHIPPED
  DELIVERED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  COD
  EASYPAISA
  JAZZCASH
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           Role            @default(CUSTOMER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         Order[]
  addresses      Address[]
  reviews        Review[]
  wishlist       WishlistItem[]
  passwordResets PasswordReset[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  emoji       String    @default("🐾")
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  description  String?          @db.Text
  price        Int
  comparePrice Int?
  categoryId   String
  category     Category         @relation(fields: [categoryId], references: [id])
  isFeatured   Boolean          @default(false)
  isActive     Boolean          @default(true)
  images       ProductImage[]
  variants     ProductVariant[]
  reviews      Review[]
  wishlist     WishlistItem[]
  orderItems   OrderItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String  @db.Text
  altText   String?
  order     Int     @default(0)
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  value         String
  priceModifier Int         @default(0)
  stock         Int         @default(0)
  orderItems    OrderItem[]
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  status        OrderStatus   @default(PENDING_COD)
  paymentMethod PaymentMethod
  txnId         String?
  subtotal      Int
  deliveryFee   Int           @default(200)
  total         Int
  fullName      String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  province      String
  postalCode    String
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  productName String
  qty         Int
  unitPrice   Int
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  body      String?  @db.Text
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model HeroSlide {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  badge     String
  headline  String   // may contain a line break (\n)
  highlight String   // substring of headline to accent-colour
  subtitle  String
  cta1Label String
  cta1Href  String
  cta2Label String
  cta2Href  String
  theme     String   @default("navy") // preset key, see lib/hero-themes.ts
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id               String   @id @default("singleton")
  storeName        String?
  storeTagline     String?
  storeDescription String?
  contactEmail     String?
  contactPhone     String?
  address          String?
  instagram        String?
  facebook         String?
  tiktok           String?
  whatsapp         String?
  codEnabled       Boolean  @default(true)
  easypaisaEnabled Boolean  @default(true)
  easypaisaTitle   String?
  easypaisaNumber  String?
  jazzcashEnabled  Boolean  @default(true)
  jazzcashTitle    String?
  jazzcashNumber   String?
  updatedAt        DateTime @updatedAt
}
